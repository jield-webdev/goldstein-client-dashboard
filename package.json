{
  "name": "goldstein-client-dashboard",
  "version": "1.0.0",
  "description": "This package provides a dashboard for interacting with the Goldstein functionalities.",
  "author": "pedrofmu",
  "license": "MIT",
  "repository": "pedrofmu/goldstein-client-dashboard",
  "main": "dist/index.js",
  "module": "dist/index.modern.js",
  "source": "src/index.tsx",
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "build": "cross-env microbundle-crl --no-compress --format modern,cjs --css-modules false",
