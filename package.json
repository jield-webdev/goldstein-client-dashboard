    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.2",
    "gh-pages": "^6.3.0",
    "microbundle-crl": "^0.13.11",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "postcss-modules-values-replace": "^4.2.2",
    "prettier": "^3.6.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
